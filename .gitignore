# --- Build & Temporary Files ---
# These are generated during compilation and should not be tracked.
bin/
obj/

# --- IDE Settings (JetBrains Rider / IntelliJ) ---
# This folder contains local IDE configurations and layouts.
.idea/

# --- Environment Specific Settings ---
# Often contains local secrets or connection strings.
appsettings.Development.json
appsettings.json

# --- User-Specific Files ---
*.user
*.userosscache
*.sln.docstates

# --- OS Generated Files ---
.DS_Store
Thumbs.db